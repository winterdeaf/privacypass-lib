+// Manual TLS impls for AmortizedBatchTokenRequest using TlsVecU16 (2-byte big-endian byte-count
+// prefix) for blinded_elements, matching the old batched-token wire format used by servers that
+// have not yet been upgraded to the QUIC-VLN encoding.
+
+impl<CS: PrivateCipherSuite> Size for AmortizedBatchTokenRequest<CS> {
+    fn tls_serialized_len(&self) -> usize {
+        let elem_len = <<CS::Group as Group>::ElemLen as Unsigned>::USIZE;
+        // token_type(2) + truncated_token_key_id(1) + length_prefix(2) + elements
+        2 + 1 + 2 + self.blinded_elements.len() * elem_len
+    }
+}
+
+impl<CS: PrivateCipherSuite> Serialize for AmortizedBatchTokenRequest<CS> {
+    fn tls_serialize<W: std::io::Write>(
+        &self,
+        writer: &mut W,
+    ) -> std::result::Result<usize, tls_codec::Error> {
+        let elem_len = <<CS::Group as Group>::ElemLen as Unsigned>::USIZE;
+        let byte_count = (self.blinded_elements.len() * elem_len) as u16;
+        let mut written = self.token_type.tls_serialize(writer)?;
+        written += self.truncated_token_key_id.tls_serialize(writer)?;
+        writer.write_all(&byte_count.to_be_bytes())?;
+        written += 2;
+        for element in &self.blinded_elements {
+            written += element.tls_serialize(writer)?;
+        }
+        Ok(written)
+    }
+}
+
+impl<CS: PrivateCipherSuite> Deserialize for AmortizedBatchTokenRequest<CS> {
+    fn tls_deserialize<R: std::io::Read>(
+        bytes: &mut R,
+    ) -> std::result::Result<Self, tls_codec::Error>
+    where
+        Self: Sized,
+    {
+        let token_type = TokenType::tls_deserialize(bytes)?;
+        let truncated_token_key_id = TruncatedTokenKeyId::tls_deserialize(bytes)?;
+        // Read TlsVecU16-style 2-byte big-endian byte count.
+        let elements_vec = TlsVecU16::<BlindedElement<CS>>::tls_deserialize(bytes)?;
+        Ok(AmortizedBatchTokenRequest {
+            token_type,
+            truncated_token_key_id,
+            blinded_elements: elements_vec.into(),
+        })
+    }
+}
